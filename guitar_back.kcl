  coincident([
    leftScallop.start,
    leftExtensionTop.start
  ])
  coincident([leftExtensionTop.end, leftEnd.start])
  coincident([leftEnd.end, bottomLeft.start])

  horizontal(bottomLeft)
  vertical(notchLeft)
  horizontal(notchTop)
  vertical(notchRight)
  horizontal(bottomRight)
  vertical(rightEnd)
  horizontal(rightExtensionTop)
  horizontal(topFlat)
  horizontal(leftExtensionTop)
  vertical(leftEnd)

  horizontalDistance([bottomLeft.start, ORIGIN]) == b2StartTrimHalfSpan
  verticalDistance([ORIGIN, bottomLeft.start]) == b2StartBottomZ
  distance([bottomLeft.start, bottomLeft.end]) == b2StartTrimHalfSpan - centerSeamNotchHalfWidth
  distance([notchLeft.start, notchLeft.end]) == centerSeamNotchHeight
  distance([notchTop.start, notchTop.end]) == centerSeamNotchHalfWidth * 2
  distance([bottomRight.start, bottomRight.end]) == b2StartTrimHalfSpan - centerSeamNotchHalfWidth
  distance([rightEnd.start, rightEnd.end]) == backBraceEndHeight
  horizontalDistance([
  rightExtensionTop.end,
  rightExtensionTop.start
]) == backTransverseBrace4KerfTrimOverrun
  horizontalDistance([
  leftExtensionTop.end,
  leftExtensionTop.start
]) == backTransverseBrace4KerfTrimOverrun
  distance([leftEnd.start, leftEnd.end]) == backBraceEndHeight
  horizontalDistance([rightScallop.start, rightScallop.end]) == backBraceScallopLength
  verticalDistance([rightScallop.end, rightScallop.start]) == backBraceScallopRise
  horizontalDistance([leftScallop.start, leftScallop.end]) == backBraceScallopLength
  verticalDistance([leftScallop.start, leftScallop.end]) == backBraceScallopRise
  horizontalDistance([rightScallop.end, rightScallop.center]) == 0in
