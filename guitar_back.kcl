  rightEnd = line(start = [var 10.16in, var -4.07in], end = [var 10.16in, var -3.89in])
  rightExtensionTop = line(start = [var 10.16in, var -3.89in], end = [var 7.16in, var -3.89in])
  rightScallop = arc(start = [var 3.16in, var -3.47in], end = [var 7.16in, var -3.89in], center = [var 7.16in, var 15.37in])
  topFlat = line(start = [var 3.16in, var -3.47in], end = [var -3.16in, var -3.47in])
