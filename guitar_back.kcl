b2StartRegion = region(point = [0in, -3.58in], sketch = b2StartProfile)
b2EndRegion = region(point = [0in, -3.57in], sketch = b2EndProfile)
backTransverseBrace2 = intersect(
  [
    loft([b2StartRegion, b2EndRegion], vDegree = 1, bezApproximateRational = true),
    clone(guitarLiningInnerPlanSolid)
  ],
  legacyMethod = true,
)
  |> appearance(color = backTransverseBraceWoodColor, metalness = 0, roughness = 78)

b3StartProfile = sketch(on = offsetPlane(XZ, offset = 6.01in)) {
  bottomLeft = line(start = [var -10.16in, var -4.07in], end = [var -0.54in, var -4.07in])
  notchLeft = line(start = [var -0.54in, var -4.07in], end = [var -0.54in, var -3.89in])
