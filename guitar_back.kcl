// Guitar back subsystem
// Back plate, binding, center seam brace, and back braces.
@settings(defaultLengthUnit = in)

import guitarOuterPlanSolid, guitarInnerPlanSolid from "guitar_outline.kcl"
import sideBackProfilePrism from "guitar_side_profile.kcl"
import backBindingProfilePrism from "guitar_top_binding_rabbet_profiles.kcl"
import guitarLiningInnerPlanSolid from "guitar_kerfed_linings.kcl"

bindingColor = "#f2ead1"
walnutBackColor = "#5a2f1a"
backBraceWoodColor = "#d8bd7a"

backArcRadius = 28ft
sideProfileArcOffset = 0.125in
backBraceGlueRadius = backArcRadius - sideProfileArcOffset
centerSeamBraceWidth = 1.0in
centerSeamBraceHeight = 0.125in
centerSeamBraceTopRadius = backBraceGlueRadius - centerSeamBraceHeight
centerSeamBraceTailY = -13.95in
centerSeamBraceNeckY = 4.55in
backBraceArcCenterY = -12.66in
backBraceArcCenterZ = 331.74in

backplate = intersect(
  [
    clone(sideBackProfilePrism),
    clone(guitarInnerPlanSolid)
  ],
  legacyMethod = true,
)
  |> appearance(color = walnutBackColor, metalness = 0, roughness = 74)

backBinding = intersect(
  [
    clone(backBindingProfilePrism),
    subtract(clone(guitarOuterPlanSolid), tools = [clone(guitarInnerPlanSolid)], legacyMethod = true)
  ],
  legacyMethod = true,
)
  |> appearance(color = bindingColor, metalness = 0, roughness = 64)

backCenterGlueSeamBraceProfile = sketch(on = YZ) {
  glueFace = arc(start = [var -13.95in, var -4.13in], end = [var 4.55in, var -3.69in], center = [var -12.66in, var 331.74in])
  topFace = arc(start = [var -13.95in, var -4.01in], end = [var 4.55in, var -3.57in], center = [var -12.66in, var 331.74in])
  neckEnd = line(start = [var 4.55in, var -3.69in], end = [var 4.55in, var -3.57in])
  tailEnd = line(start = [var -13.95in, var -4.01in], end = [var -13.95in, var -4.13in])

  coincident([glueFace.end, neckEnd.start])
  coincident([neckEnd.end, topFace.end])
  coincident([topFace.start, tailEnd.start])
  coincident([tailEnd.end, glueFace.start])
  coincident([topFace.center, glueFace.center])

  vertical(neckEnd)
  vertical(tailEnd)

  horizontalDistance([glueFace.center, ORIGIN]) == 0in - backBraceArcCenterY
  verticalDistance([ORIGIN, glueFace.center]) == backBraceArcCenterZ
  horizontalDistance([glueFace.start, ORIGIN]) == 0in - centerSeamBraceTailY
  horizontalDistance([ORIGIN, glueFace.end]) == centerSeamBraceNeckY
  radius(glueFace) == backBraceGlueRadius
  distance([glueFace.end, glueFace.center]) == backBraceGlueRadius
  radius(topFace) == centerSeamBraceTopRadius
  distance([topFace.end, topFace.center]) == centerSeamBraceTopRadius
}

backCenterGlueSeamBraceRegion = region(point = [0in, -3.83in], sketch = backCenterGlueSeamBraceProfile)
backCenterGlueSeamBraceBlank = extrude(
  backCenterGlueSeamBraceRegion,
  length = centerSeamBraceWidth,
  symmetric = true,
  method = NEW,
)
backCenterGlueSeamBrace = intersect(
  [
    backCenterGlueSeamBraceBlank,
    clone(guitarInnerPlanSolid)
  ],
  legacyMethod = true,
)
  |> appearance(color = backBraceWoodColor, metalness = 0, roughness = 78)

backTransverseBraceWoodColor = "#d6b66f"
centerSeamNotchHalfWidth = 0.54in
centerSeamNotchHeight = 0.18in
backBraceEndHeight = 0.18in
backBraceFullHeight = 0.60in
backBraceScallopLength = 4in
backBraceScallopRise = 0.42in
backBraceScallopRadius = 19.2576in
backTransverseBrace4KerfTrimOverrun = 3.0in

b1StartHalfSpan = 5.70in
b1EndHalfSpan = 5.68in
b2StartHalfSpan = 5.37in
b2EndHalfSpan = 5.32in
b3StartHalfSpan = 7.16in
b3EndHalfSpan = 7.12in
b4StartHalfSpan = 7.31in
b4EndHalfSpan = 7.32in
b1StartTrimHalfSpan = b1StartHalfSpan + backTransverseBrace4KerfTrimOverrun
b1EndTrimHalfSpan = b1EndHalfSpan + backTransverseBrace4KerfTrimOverrun
b2StartTrimHalfSpan = b2StartHalfSpan + backTransverseBrace4KerfTrimOverrun
b2EndTrimHalfSpan = b2EndHalfSpan + backTransverseBrace4KerfTrimOverrun
b3StartTrimHalfSpan = b3StartHalfSpan + backTransverseBrace4KerfTrimOverrun
b3EndTrimHalfSpan = b3EndHalfSpan + backTransverseBrace4KerfTrimOverrun
b4StartTrimHalfSpan = b4StartHalfSpan + backTransverseBrace4KerfTrimOverrun
b4EndTrimHalfSpan = b4EndHalfSpan + backTransverseBrace4KerfTrimOverrun

b1StartBottomZ = -3.77in
b1EndBottomZ = -3.75in
b2StartBottomZ = -3.95in
b2EndBottomZ = -3.94in
b3StartBottomZ = -4.07in
b3EndBottomZ = -4.06in
b4StartBottomZ = -4.13in
b4EndBottomZ = -4.12in

b1StartProfile = sketch(on = offsetPlane(XZ, offset = -2.99in)) {
  bottomLeft = line(start = [var -8.70in, var -3.77in], end = [var -0.54in, var -3.77in])
  notchLeft = line(start = [var -0.54in, var -3.77in], end = [var -0.54in, var -3.59in])
  notchTop = line(start = [var -0.54in, var -3.59in], end = [var 0.54in, var -3.59in])
  notchRight = line(start = [var 0.54in, var -3.59in], end = [var 0.54in, var -3.77in])
  bottomRight = line(start = [var 0.54in, var -3.77in], end = [var 8.70in, var -3.77in])
  rightEnd = line(start = [var 8.70in, var -3.77in], end = [var 8.70in, var -3.59in])
  rightExtensionTop = line(start = [var 8.70in, var -3.59in], end = [var 5.70in, var -3.59in])
  rightScallop = arc(start = [var 1.70in, var -3.17in], end = [var 5.70in, var -3.59in], center = [var 5.70in, var 15.67in])
  topFlat = line(start = [var 1.70in, var -3.17in], end = [var -1.70in, var -3.17in])
  leftScallop = arc(start = [var -5.70in, var -3.59in], end = [var -1.70in, var -3.17in], center = [var -5.70in, var 15.67in])
  leftExtensionTop = line(start = [var -5.70in, var -3.59in], end = [var -8.70in, var -3.59in])
  leftEnd = line(start = [var -8.70in, var -3.59in], end = [var -8.70in, var -3.77in])

  coincident([bottomLeft.end, notchLeft.start])
  coincident([notchLeft.end, notchTop.start])
  coincident([notchTop.end, notchRight.start])
  coincident([notchRight.end, bottomRight.start])
  coincident([bottomRight.end, rightEnd.start])
  coincident([rightEnd.end, rightExtensionTop.start])
  coincident([
    rightExtensionTop.end,
    rightScallop.end
  ])
  coincident([rightScallop.start, topFlat.start])
  coincident([topFlat.end, leftScallop.end])
  coincident([
    leftScallop.start,
    leftExtensionTop.start
  ])
  coincident([leftExtensionTop.end, leftEnd.start])
  coincident([leftEnd.end, bottomLeft.start])

  horizontal(bottomLeft)
  vertical(notchLeft)
  horizontal(notchTop)
  vertical(notchRight)
  horizontal(bottomRight)
  vertical(rightEnd)
  horizontal(rightExtensionTop)
  horizontal(topFlat)
  horizontal(leftExtensionTop)
  vertical(leftEnd)

  horizontalDistance([bottomLeft.start, ORIGIN]) == b1StartTrimHalfSpan
  verticalDistance([ORIGIN, bottomLeft.start]) == b1StartBottomZ
  distance([bottomLeft.start, bottomLeft.end]) == b1StartTrimHalfSpan - centerSeamNotchHalfWidth
  distance([notchLeft.start, notchLeft.end]) == centerSeamNotchHeight
  distance([notchTop.start, notchTop.end]) == centerSeamNotchHalfWidth * 2
  distance([bottomRight.start, bottomRight.end]) == b1StartTrimHalfSpan - centerSeamNotchHalfWidth
  distance([rightEnd.start, rightEnd.end]) == backBraceEndHeight
  horizontalDistance([
  rightExtensionTop.end,
  rightExtensionTop.start
]) == backTransverseBrace4KerfTrimOverrun
  horizontalDistance([
  leftExtensionTop.end,
  leftExtensionTop.start
]) == backTransverseBrace4KerfTrimOverrun
  distance([leftEnd.start, leftEnd.end]) == backBraceEndHeight
  horizontalDistance([rightScallop.start, rightScallop.end]) == backBraceScallopLength
  verticalDistance([rightScallop.end, rightScallop.start]) == backBraceScallopRise
  horizontalDistance([leftScallop.start, leftScallop.end]) == backBraceScallopLength
  verticalDistance([leftScallop.start, leftScallop.end]) == backBraceScallopRise
  horizontalDistance([rightScallop.end, rightScallop.center]) == 0in
  verticalDistance([rightScallop.end, rightScallop.center]) == backBraceScallopRadius
  horizontalDistance([leftScallop.start, leftScallop.center]) == 0in
  verticalDistance([leftScallop.start, leftScallop.center]) == backBraceScallopRadius
  radius(leftScallop) == backBraceScallopRadius
  radius(rightScallop) == backBraceScallopRadius
}

b1EndProfile = sketch(on = offsetPlane(XZ, offset = -3.41in)) {
  bottomLeft = line(start = [var -8.68in, var -3.75in], end = [var -0.54in, var -3.75in])
  notchLeft = line(start = [var -0.54in, var -3.75in], end = [var -0.54in, var -3.57in])
  notchTop = line(start = [var -0.54in, var -3.57in], end = [var 0.54in, var -3.57in])
  notchRight = line(start = [var 0.54in, var -3.57in], end = [var 0.54in, var -3.75in])
  bottomRight = line(start = [var 0.54in, var -3.75in], end = [var 8.68in, var -3.75in])
  rightEnd = line(start = [var 8.68in, var -3.75in], end = [var 8.68in, var -3.57in])
  rightExtensionTop = line(start = [var 8.68in, var -3.57in], end = [var 5.68in, var -3.57in])
  rightScallop = arc(start = [var 1.68in, var -3.15in], end = [var 5.68in, var -3.57in], center = [var 5.68in, var 15.69in])
  topFlat = line(start = [var 1.68in, var -3.15in], end = [var -1.68in, var -3.15in])
  leftScallop = arc(start = [var -5.68in, var -3.57in], end = [var -1.68in, var -3.15in], center = [var -5.68in, var 15.69in])
  leftExtensionTop = line(start = [var -5.68in, var -3.57in], end = [var -8.68in, var -3.57in])
  leftEnd = line(start = [var -8.68in, var -3.57in], end = [var -8.68in, var -3.75in])

  coincident([bottomLeft.end, notchLeft.start])
  coincident([notchLeft.end, notchTop.start])
  coincident([notchTop.end, notchRight.start])
  coincident([notchRight.end, bottomRight.start])
  coincident([bottomRight.end, rightEnd.start])
  coincident([rightEnd.end, rightExtensionTop.start])
  coincident([
    rightExtensionTop.end,
    rightScallop.end
  ])
  coincident([rightScallop.start, topFlat.start])
  coincident([topFlat.end, leftScallop.end])
  coincident([
    leftScallop.start,
    leftExtensionTop.start
  ])
  coincident([leftExtensionTop.end, leftEnd.start])
  coincident([leftEnd.end, bottomLeft.start])

  horizontal(bottomLeft)
  vertical(notchLeft)
  horizontal(notchTop)
  vertical(notchRight)
  horizontal(bottomRight)
  vertical(rightEnd)
  horizontal(rightExtensionTop)
  horizontal(topFlat)
  horizontal(leftExtensionTop)
  vertical(leftEnd)

  horizontalDistance([bottomLeft.start, ORIGIN]) == b1EndTrimHalfSpan
  verticalDistance([ORIGIN, bottomLeft.start]) == b1EndBottomZ
  distance([bottomLeft.start, bottomLeft.end]) == b1EndTrimHalfSpan - centerSeamNotchHalfWidth
  distance([notchLeft.start, notchLeft.end]) == centerSeamNotchHeight
  distance([notchTop.start, notchTop.end]) == centerSeamNotchHalfWidth * 2
  distance([bottomRight.start, bottomRight.end]) == b1EndTrimHalfSpan - centerSeamNotchHalfWidth
  distance([rightEnd.start, rightEnd.end]) == backBraceEndHeight
  horizontalDistance([
  rightExtensionTop.end,
  rightExtensionTop.start
]) == backTransverseBrace4KerfTrimOverrun
  horizontalDistance([
  leftExtensionTop.end,
  leftExtensionTop.start
]) == backTransverseBrace4KerfTrimOverrun
  distance([leftEnd.start, leftEnd.end]) == backBraceEndHeight
  horizontalDistance([rightScallop.start, rightScallop.end]) == backBraceScallopLength
  verticalDistance([rightScallop.end, rightScallop.start]) == backBraceScallopRise
  horizontalDistance([leftScallop.start, leftScallop.end]) == backBraceScallopLength
  verticalDistance([leftScallop.start, leftScallop.end]) == backBraceScallopRise
  horizontalDistance([rightScallop.end, rightScallop.center]) == 0in
  verticalDistance([rightScallop.end, rightScallop.center]) == backBraceScallopRadius
  horizontalDistance([leftScallop.start, leftScallop.center]) == 0in
  verticalDistance([leftScallop.start, leftScallop.center]) == backBraceScallopRadius
  radius(leftScallop) == backBraceScallopRadius
  radius(rightScallop) == backBraceScallopRadius
}

b1StartRegion = region(point = [0in, -3.38in], sketch = b1StartProfile)
b1EndRegion = region(point = [0in, -3.36in], sketch = b1EndProfile)
backTransverseBrace1 = intersect(
  [
    loft([b1StartRegion, b1EndRegion], vDegree = 1, bezApproximateRational = true),
    clone(guitarLiningInnerPlanSolid)
  ],
  legacyMethod = true,
)
  |> appearance(color = backTransverseBraceWoodColor, metalness = 0, roughness = 78)

b2StartProfile = sketch(on = offsetPlane(XZ, offset = 1.61in)) {
  bottomLeft = line(start = [var -8.37in, var -3.95in], end = [var -0.54in, var -3.95in])
  notchLeft = line(start = [var -0.54in, var -3.95in], end = [var -0.54in, var -3.77in])
  notchTop = line(start = [var -0.54in, var -3.77in], end = [var 0.54in, var -3.77in])
  notchRight = line(start = [var 0.54in, var -3.77in], end = [var 0.54in, var -3.95in])
  bottomRight = line(start = [var 0.54in, var -3.95in], end = [var 8.37in, var -3.95in])
  rightEnd = line(start = [var 8.37in, var -3.95in], end = [var 8.37in, var -3.77in])
  rightExtensionTop = line(start = [var 8.37in, var -3.77in], end = [var 5.37in, var -3.77in])
