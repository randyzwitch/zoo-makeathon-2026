backLiningBlockButtJointRegion = region(point = [0in, 0in], sketch = backLiningBlockButtJointProfile)
backLiningBlockButtJointPrism = extrude(
  backLiningBlockButtJointRegion,
  length = blockClipDepth,
  symmetric = true,
  method = NEW,
)

backLiningPlanBandWithBlockButts = intersect(
  [
    subtract(clone(guitarInnerPlanSolid), tools = [clone(guitarLiningInnerPlanSolid)], legacyMethod = true),
    backLiningBlockButtJointPrism
  ],
  legacyMethod = true,
)

rimBackKerfedLining = intersect(
  [
    backLiningPlanBandWithBlockButts,
    clone(backLiningProfilePrism)
  ],
  legacyMethod = true,
)
  |> appearance(color = liningWoodColor, metalness = 0, roughness = 82)

