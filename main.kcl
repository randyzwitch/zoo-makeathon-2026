@settings(defaultLengthUnit = in)

// Lightweight bridge-work assembly.
// Shows only the soundboard, rosette, bracing/patches attached to the soundboard,
// and the external bridge so bridge modeling iterations render faster.
// Geometry source modules are untouched.

import soundboard from "guitar_soundboard_solid.kcl"
import rosetteInnerPurfling, rosetteMainInlay, rosetteOuterPurfling from "guitar_rosette.kcl"
import soundboardBracing from "guitar_soundboard_bracing.kcl"
import soundboardTopSideBraces from "guitar_soundboard_top_side_braces.kcl"
import bridgePlate from "guitar_bridge_plate.kcl"
import soundholeReinforcement from "guitar_soundhole_reinforcement.kcl"
import bridge from "guitar_bridge.kcl"

// Visible working set for adding the external bridge.
visibleSoundboard = soundboard
visibleRosetteInnerPurfling = rosetteInnerPurfling
visibleRosetteMainInlay = rosetteMainInlay
visibleRosetteOuterPurfling = rosetteOuterPurfling
visibleSoundboardBracing = soundboardBracing
visibleSoundboardTopSideBraces = soundboardTopSideBraces
visibleBridgePlate = bridgePlate
visibleSoundholeReinforcement = soundholeReinforcement
visibleBridge = bridge
