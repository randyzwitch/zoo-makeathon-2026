  horizontalDistance([ORIGIN, upperRightEdge.end]) == 4.267in
  verticalDistance([ORIGIN, upperRightEdge.end]) == -0.35in
  verticalDistance([ORIGIN, lowerRightEdge.end]) == -3.45in
}

