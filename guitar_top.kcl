topSideBrace1LeftReach = 2.0in
topSideBrace1RightRawReach = 2.30in
topSideBrace1EndHeight = 0.08in
topSideBrace1FullHeight = 0.30in
topSideBrace1XBraceEndFlatLength = 0.90in
topSideBrace1KerfEndFlatLength = 0.45in
topSideBrace1CrownFlatLength = 0.70in
topSideBrace1RightScallopRadius = 6.0in
topSideBrace1LeftScallopRadius = 6.0in

topSideBrace1Profile = sketch(on = YZ) {
  glueFace = line(start = [var -2.0in, var -0.065in], end = [var 2.30in, var -0.065in])
  rightEnd = line(start = [var 2.30in, var -0.065in], end = [var 2.30in, var -0.145in])
  rightFlat = line(start = [var 2.30in, var -0.145in], end = [var 1.40in, var -0.145in])
  rightScallop = arc(start = [var 1.40in, var -0.145in], end = [var 0.35in, var -0.365in], center = [var 2.10in, var -6.11in])
  crownFlat = line(start = [var 0.35in, var -0.365in], end = [var -0.35in, var -0.365in])
  leftScallop = arc(start = [var -0.35in, var -0.365in], end = [var -1.55in, var -0.145in], center = [var -2.02in, var -6.13in])
  leftFlat = line(start = [var -1.55in, var -0.145in], end = [var -2.0in, var -0.145in])
  leftEnd = line(start = [var -2.0in, var -0.145in], end = [var -2.0in, var -0.065in])
  coincident([glueFace.end, rightEnd.start])
  coincident([rightEnd.end, rightFlat.start])
  coincident([rightFlat.end, rightScallop.start])
  coincident([rightScallop.end, crownFlat.start])
  coincident([crownFlat.end, leftScallop.start])
  coincident([leftScallop.end, leftFlat.start])
  coincident([leftFlat.end, leftEnd.start])
  coincident([leftEnd.end, glueFace.start])
  horizontal(glueFace)
  vertical(rightEnd)
  horizontal(rightFlat)
  horizontal(crownFlat)
  horizontal(leftFlat)
  vertical(leftEnd)
  horizontalDistance([glueFace.start, ORIGIN]) == topSideBrace1LeftReach
  verticalDistance([ORIGIN, glueFace.start]) == soundboardBraceGlueZ
  distance([glueFace.start, glueFace.end]) == topSideBrace1LeftReach + topSideBrace1RightRawReach
  distance([rightEnd.start, rightEnd.end]) == topSideBrace1EndHeight
  distance([leftEnd.start, leftEnd.end]) == topSideBrace1EndHeight
  distance([rightFlat.start, rightFlat.end]) == topSideBrace1XBraceEndFlatLength
  distance([leftFlat.start, leftFlat.end]) == topSideBrace1KerfEndFlatLength
  horizontalDistance([ORIGIN, crownFlat.start]) == topSideBrace1CrownFlatLength / 2
  horizontalDistance([crownFlat.end, ORIGIN]) == topSideBrace1CrownFlatLength / 2
  distance([crownFlat.start, crownFlat.end]) == topSideBrace1CrownFlatLength
  verticalDistance([crownFlat.start, glueFace.end]) == topSideBrace1FullHeight
  radius(rightScallop) == topSideBrace1RightScallopRadius
  distance([
  rightScallop.start,
  rightScallop.center
]) == topSideBrace1RightScallopRadius
  radius(leftScallop) == topSideBrace1LeftScallopRadius
  distance([leftScallop.start, leftScallop.center]) == topSideBrace1LeftScallopRadius
}

